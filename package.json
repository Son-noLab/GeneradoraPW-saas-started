{
  "name": "generadorapw-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "powershell -NoProfile -Command \"$p=(Get-NetTCPConnection -LocalPort 3000 -State Listen -EA SilentlyContinue).OwningProcess; if($p){taskkill /F /PID $p /T 2>$null}\" & echo .",
    "dev": "node --max-old-space-size=1024 node_modules/next/dist/bin/next dev --webpack",
    "build": "node --max-old-space-size=1024 node_modules/next/dist/bin/next build",
    "start": "next start",
    "clean": "rmdir /s /q .next 2>nul & echo Cache limpio",
    "cleandev": "npm run clean && npm run dev"
  },
  "dependencies": {
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "autoprefixer": "^10.5.0",
    "lenis": "^1.3.23",
    "lucide-react": "latest",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
